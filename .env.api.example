API_PORT=3001
JWT_SECRET=replace-with-a-random-secret-at-least-32-chars
CORS_ORIGINS=http://localhost:3002,http://127.0.0.1:3002

DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=ChangeMe_123456
DEFAULT_ADMIN_EMAIL=admin@example.com

# 阿里云 OSS 配置
OSS_REGION=oss-cn-hangzhou
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_BUCKET=your-bucket-name
# 可选：自定义域名（绑定 CDN 后填写，如 https://cdn.example.com）
# OSS_CUSTOM_DOMAIN=https://cdn.example.com