{
  "name": "jiyun-admin-web",
  "private": true,
  "version": "0.2.1",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3002 --host=127.0.0.1",
    "api": "tsx --tsconfig server/tsconfig.json server/index.ts",
    "api:dev": "tsx watch --tsconfig server/tsconfig.json server/index.ts",
    "dev:all": "concurrently \"npm run api:dev\" \"npm run dev\"",
    "seed:parcels": "tsx scripts/seed-parcels.ts",
    "build": "vite build",
    "preview": "vite preview",
    "start:public": "concurrently \"npm run api\" \"npm run preview\""
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.546.0",
    "mysql2": "^3.11.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
